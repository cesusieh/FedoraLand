#!/usr/bin/env bash
set -euo pipefail

install -d -m 0755 /var/lib/fedoraland

if [ ! -x /usr/bin/zsh ]; then
  touch /var/lib/fedoraland/default-shell.done
  exit 0
fi

while IFS=: read -r user _ uid gid _ home shell; do
  if [ "${uid}" -lt 1000 ] || [ "${uid}" -ge 60000 ]; then
    continue
  fi

  if [ "${shell}" != /usr/bin/zsh ]; then
    usermod --shell /usr/bin/zsh "${user}"
  fi

  if [ -d "${home}" ] && [ ! -e "${home}/.zshrc" ] && [ -r /etc/skel/.zshrc ]; then
    install -m 0644 -o "${user}" -g "${gid}" /etc/skel/.zshrc "${home}/.zshrc"
  fi
done < /etc/passwd

touch /var/lib/fedoraland/default-shell.done
